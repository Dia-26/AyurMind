# AyurMind Frontend — Environment Variables
# Copy to .env and fill in values

# Optional: URL of Python NLP backend
# If set, all NLP calls route through the backend (better NLP)
# If not set, the app calls Groq directly from the browser (fallback mode)
VITE_API_BASE_URL=http://localhost:8000

VITE_APP_NAME=AyurMind
VITE_APP_VERSION=2.0.0
